{% extends "_base.html.j2" %}
{% import "_macros.html.j2" as m %}
{% set severity = "warning" %}

{% block preheader %}A login passed the password check but failed at the TOTP step.{% endblock %}

{% block header_eyebrow %}MFA failure{% endblock %}
{% block header_title %}TOTP verification failed{% endblock %}

{% block content %}
<p style="margin:0 0 14px 0;font-size:14px;">
  Someone authenticated with a valid password but failed the TOTP
  challenge. One occurrence is usually a typo or a stale clock — repeated
  ones from new IPs are an attack signal.
</p>

{{ m.kv_table([
  ("Event",  event_type),
  ("When",   when_str),
  ("IP",     ip),
  ("Agent",  user_agent),
  ("Reason", extra),
]) }}

{{ m.callout(
  "warning",
  "Implications: the password is known to the requester. If this IP is
   not yours, treat the password as compromised."
) }}

{{ m.action_list([
  "If the IP is unfamiliar, rotate the admin password immediately.",
  "Cross-reference auth_events: a burst of login_mfa_failed rows from one IP precedes an attempted bypass.",
  "If you see only one or two from a familiar IP, no action — the rate-limit / replay guard handled it.",
]) }}
{% endblock %}
