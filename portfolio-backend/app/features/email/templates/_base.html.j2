{#-
  Shared HTML layout. Children override:
    - header_eyebrow  : small uppercase tag above the title
    - header_title    : main title rendered next to the severity bar
    - content         : main body block
    - footer_extra    : optional appended footer line
  And set:
    - severity        : "info" | "warning" | "critical" — drives header color

  Inline CSS only — no <style> block (Gmail/Outlook strip them silently),
  no web fonts, no background images. Layout is one nested table for max
  client compatibility (Outlook's Word-engine renderer ignores divs).
-#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="x-apple-disable-message-reformatting">
  <title>{{ subject_text|default('Portfolio') }}</title>
</head>
<body style="margin:0;padding:0;background:#f4f5f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#0f172a;line-height:1.5;">
  <span style="display:none !important;visibility:hidden;mso-hide:all;font-size:1px;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;">
    {%- block preheader -%}{%- endblock -%}
  </span>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f4f5f7;padding:24px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:10px;border:1px solid #e2e8f0;overflow:hidden;">
          <tr>
            <td style="background:
              {%- if severity == 'critical' -%}#b91c1c
              {%- elif severity == 'warning' -%}#b45309
              {%- else -%}#1e293b
              {%- endif -%};color:#ffffff;padding:22px 28px;">
              <div style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;opacity:0.75;">
                {%- block header_eyebrow -%}Portfolio Admin{%- endblock -%}
              </div>
              <div style="font-size:20px;font-weight:600;margin-top:4px;line-height:1.3;">
                {%- block header_title -%}Notification{%- endblock -%}
              </div>
            </td>
          </tr>
          <tr>
            <td style="padding:24px 28px;font-size:14px;color:#0f172a;">
              {%- block content -%}{%- endblock -%}
            </td>
          </tr>
          <tr>
            <td style="background:#f8fafc;color:#64748b;padding:14px 28px;font-size:12px;border-top:1px solid #e2e8f0;line-height:1.5;">
              <div>Portfolio Admin · automated message · do not reply</div>
              {% block footer_extra %}{% endblock %}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
