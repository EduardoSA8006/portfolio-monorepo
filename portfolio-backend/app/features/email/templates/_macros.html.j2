{#-
  Reusable HTML email macros. Imported by templates via:
    {% import "_macros.html.j2" as m %}

  All inline-styled — clients still strip <style>.
-#}

{%- macro kv_table(rows) -%}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;border-collapse:separate;margin:18px 0;">
  {%- set total = rows|length -%}
  {%- for label, value in rows -%}
  <tr>
    <td style="padding:10px 14px;font-size:12px;color:#64748b;width:30%;vertical-align:top;letter-spacing:0.3px;text-transform:uppercase;
      {%- if not loop.last %}border-bottom:1px solid #e2e8f0;{% endif -%}">{{ label }}</td>
    <td style="padding:10px 14px;font-size:13px;color:#0f172a;font-family:'SFMono-Regular',Consolas,'Liberation Mono',Menlo,monospace;word-break:break-all;
      {%- if not loop.last %}border-bottom:1px solid #e2e8f0;{% endif -%}">
      {%- if value is none or value == '' -%}
        <span style="color:#94a3b8;font-style:italic;">(none)</span>
      {%- else -%}
        {{ value }}
      {%- endif -%}
    </td>
  </tr>
  {%- endfor -%}
</table>
{%- endmacro %}

{%- macro callout(severity, text) -%}
<div style="margin:18px 0;padding:12px 16px;border-radius:8px;font-size:13px;line-height:1.55;
  {%- if severity == 'critical' %}background:#fef2f2;border-left:4px solid #dc2626;color:#7f1d1d;
  {%- elif severity == 'warning' %}background:#fffbeb;border-left:4px solid #f59e0b;color:#78350f;
  {%- else %}background:#eff6ff;border-left:4px solid #3b82f6;color:#1e3a8a;
  {%- endif %}">
  {{ text }}
</div>
{%- endmacro %}

{%- macro action_list(items) -%}
<div style="margin:18px 0;font-size:13px;color:#0f172a;">
  <div style="font-size:12px;font-weight:600;letter-spacing:0.3px;text-transform:uppercase;color:#475569;margin-bottom:6px;">What to do</div>
  <ol style="margin:0;padding-left:20px;line-height:1.6;">
    {%- for item in items -%}
    <li style="margin-bottom:4px;">{{ item }}</li>
    {%- endfor -%}
  </ol>
</div>
{%- endmacro %}

{%- macro big_code(code) -%}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:22px 0;">
  <tr>
    <td align="center" style="background:#0f172a;color:#f8fafc;padding:24px;border-radius:10px;font-family:'SFMono-Regular',Consolas,'Liberation Mono',Menlo,monospace;font-size:34px;font-weight:600;letter-spacing:0.4em;">
      {{ code }}
    </td>
  </tr>
</table>
{%- endmacro %}
