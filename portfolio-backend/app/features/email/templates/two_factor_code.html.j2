{% extends "_base.html.j2" %}
{% import "_macros.html.j2" as m %}
{% set severity = "info" %}

{% block preheader %}Your sign-in verification code expires in {{ ttl_minutes }} minute{% if ttl_minutes != 1 %}s{% endif %}.{% endblock %}

{% block header_eyebrow %}Verification{% endblock %}
{% block header_title %}Your sign-in code{% endblock %}

{% block content %}
<p style="margin:0 0 8px 0;font-size:14px;">Hi {{ name }},</p>
<p style="margin:0 0 4px 0;font-size:14px;color:#475569;">
  Enter this code to finish signing in. It expires in <strong>{{ ttl_minutes }} minute{% if ttl_minutes != 1 %}s{% endif %}</strong>.
</p>

{{ m.big_code(code) }}

{{ m.callout(
  "warning",
  "If you did not request this code, ignore this email and consider rotating your password — someone may have your credentials."
) }}
{% endblock %}
