# ── Secrets ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Minimum 32 chars. Placeholder values are rejected at startup.
#
# SECRET_KEY  → general app secret (signing, future use).
#               Rotating this does NOT affect stored email hashes.
#
# EMAIL_PEPPER → dedicated HMAC key for email hashing (shared/security.py).
#                Rotating this requires re-hashing every email_hash in the DB.
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_secrets_token_urlsafe_64
EMAIL_PEPPER=REPLACE_WITH_OUTPUT_OF_secrets_token_urlsafe_64

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=REPLACE_ME
DATABASE_URL=postgresql+asyncpg://portfolio:REPLACE_ME@postgres:5432/portfolio
DATABASE_URL_SYNC=postgresql+psycopg2://portfolio:REPLACE_ME@postgres:5432/portfolio

# ── Redis (sessions / rate-limit / MFA challenges) ───────────────────────────
# Dedicated instance — the Celery worker has no route to this one.
REDIS_PASSWORD=REPLACE_ME
REDIS_URL=redis://:REPLACE_ME@redis:6379/0

# ── Celery (broker + result backend, DEDICATED Redis) ────────────────────────
# Second Redis instance with its own requirepass and on its own Docker
# network. A compromise of a Celery task cannot reach auth:session:* keys.
CELERY_REDIS_PASSWORD=REPLACE_ME
CELERY_BROKER_URL=redis://:REPLACE_ME@redis_celery:6379/0
CELERY_RESULT_BACKEND=redis://:REPLACE_ME@redis_celery:6379/1

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production

# ── hCaptcha ─────────────────────────────────────────────────────────────────
# Required in production — login requires a valid captcha after the first
# failure in any given IP+email pair. In development both keys may be empty
# and captcha.verify always returns ok=True.
#
# Get keys from https://dashboard.hcaptcha.com. The site_key is public (served
# via GET /auth/config); the secret_key must stay server-side.
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
HCAPTCHA_VERIFY_URL=https://api.hcaptcha.com/siteverify
HCAPTCHA_TIMEOUT_SECONDS=3.0

# ── Login rate-limit extensions ──────────────────────────────────────────────
# Global per-email lockout now only fires when distinct IPs >= this many have
# tripped the per-IP counter within the lockout window. Prevents a single
# abusive IP from DoS-locking the admin account.
LOGIN_LOCKOUT_DISTINCT_IPS=3
LOGIN_LOCKOUT_WINDOW_SECONDS=1800

# Under degraded mode (hCaptcha siteverify unreachable), the per-IP attempt
# cap drops to this for the 60s auto-renewing degraded window.
LOGIN_MAX_ATTEMPTS_DEGRADED=2

# ── Session / Auth ────────────────────────────────────────────────────────────
# SESSION_MAX_AGE_SECONDS MUST equal SESSION_ABSOLUTE_SECONDS (default 28800
# = 8h). If they diverge, either the cookie expires before the server
# session (premature 401) or the server session expires while the cookie
# lingers in the browser (also 401 on the next request). The validator
# enforces equality at startup.
SESSION_TOKEN_LENGTH=48
SESSION_ROTATE_SECONDS=3600
SESSION_MAX_AGE_SECONDS=28800
CSRF_TOKEN_LENGTH=48

# ── Cookies ───────────────────────────────────────────────────────────────────
# Production (behind Traefik + HTTPS): secure=true, samesite=lax.
# Dev (no TLS): override to secure=false in docker-compose.override.yml.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# ── Proxy headers ─────────────────────────────────────────────────────────────
# TRUE in production behind Traefik; the CIDR must match the `edge` Docker
# network subnet so only the real Traefik container can set X-Forwarded-For.
# Never use ["*"] — the validator rejects it.
TRUST_PROXY_HEADERS=true
# Pinned to Traefik's static IP on the `edge` network (see
# deploy/traefik/docker-compose.yml). Trusting the entire 172.28.0.0/16
# subnet would let any container on `edge` inject X-Forwarded-For and
# defeat per-IP rate limiting; the /32 closes that vector. If you change
# Traefik's ipv4_address, change this in lock-step.
TRUSTED_PROXY_CIDRS=["172.28.0.10/32"]

# ── Readiness probe ──────────────────────────────────────────────────────────
# /health stays public. /health/ready exposes DB/Redis state and is restricted
# to these CIDRs after trusted proxy header processing.
READINESS_ALLOWED_CIDRS=["127.0.0.1/32","::1/128","172.28.0.0/16"]

# ── CORS / Hosts ──────────────────────────────────────────────────────────────
# JSON arrays. Never use ["*"] with allow_credentials=True.
ALLOWED_ORIGINS=["https://eduardoalves.online"]
ALLOWED_HOSTS=["api.eduardoalves.online"]

# ── Runtime sizing (uvicorn) ─────────────────────────────────────────────────
# Number of uvicorn workers. The Dockerfile defaults to 2, sized for a
# 2-vCPU VPS. Bump to ~(2 * vCPU) on a beefier host. Setting this in
# .env keeps the image immutable across hardware tiers.
WEB_CONCURRENCY=2

# ── SMTP / Email ─────────────────────────────────────────────────────────────
# Master flag. Leave EMAIL_ENABLED=false in environments without SMTP
# credentials — every features.email.service.send_* call becomes a no-op.
# Settings.model_validator refuses to start with EMAIL_ENABLED=true and
# missing host / from-address.
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=portfolio@example.com
# Use an app-specific password / token issued by your provider — never the
# raw account password. App passwords can be revoked individually.
EMAIL_SMTP_PASSWORD=REPLACE_ME
# Mutually exclusive: STARTTLS on 587 (default) vs implicit TLS on 465.
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_FROM_ADDRESS=portfolio@example.com
EMAIL_FROM_NAME=Portfolio Admin
EMAIL_TIMEOUT_SECONDS=10
# Single inbox that receives security alerts (cookie_signature_invalid,
# login_lockout_triggered, admin_recovery). Required when
# EMAIL_SECURITY_ALERTS_ENABLED=true in production.
EMAIL_ADMIN_RECIPIENT=admin@example.com
# Independent of EMAIL_ENABLED: with this off, transactional 2FA email
# keeps working but the admin inbox does NOT get fanned-out alerts.
EMAIL_SECURITY_ALERTS_ENABLED=true
# Email-based 2FA code parameters. Length is in digits, TTL covers the
# round-trip including the user typing the code.
EMAIL_2FA_CODE_LENGTH=6
EMAIL_2FA_CODE_TTL_SECONDS=300
EMAIL_2FA_MAX_ATTEMPTS=5
