# PostgreSQL
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio_secret
DATABASE_URL=postgresql+asyncpg://portfolio:portfolio_secret@postgres:5432/portfolio
DATABASE_URL_SYNC=postgresql+psycopg2://portfolio:portfolio_secret@postgres:5432/portfolio

# Redis
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0

# Celery
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret@redis:6379/2

# App
APP_ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Admin session config
SESSION_TOKEN_LENGTH=48
SESSION_ROTATE_SECONDS=3600
SESSION_MAX_AGE_SECONDS=86400
CSRF_TOKEN_LENGTH=48
