# Frontend environment template. Copy to .env and edit as needed.
#
# `.env` is consumed by:
#   - `pnpm dev` / `pnpm build` when running the frontend natively, and
#   - `docker compose build frontend` (passed via
#     --env-file portfolio-frontend/.env) for the build-time ARG that
#     inlines the API URL into the standalone bundle.
#
# Public URL the browser bundle hits. Inlined into the JS bundle at build
# time, so it must be set per environment:
#   dev  → http://localhost:8000
#   prod → https://api.eduardoalves.online
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
